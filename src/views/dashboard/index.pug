extends ../layouts/main.pug

block metadata

block content
  .container.py-5
    if (currentUser)
      //- --- CABECERA DE PERFIL ---
      - const user = currentUser
      include ../partials/_userHeader.pug
    else 
      .alert.alert-warning.text-center.rounded-4 No hay usuario cargado en la sesión

    //- --- VISTAS ---
    .mb-4
      h3.fw-bold.text-dark Explora tu contenido
    
    .row.g-4
      .col-md-4
        a.card.h-100.border-0.shadow-sm.rounded-4.text-decoration-none.hover-zoom.bg-white(href="/dashboard/posts")
          .card-body.p-4.text-center
            .d-inline-flex.align-items-center.justify-content-center.bg-primary-subtle.text-primary.rounded-circle.mb-3(style="width: 64px; height: 64px;")
              i.fa-solid.fa-images.fs-3
            h4.fw-bold.text-dark Mis Posts
            p.text-secondary.mb-0 Administra y visualiza todas tus fotografías subidas.
      
      .col-md-4
        a.card.h-100.border-0.shadow-sm.rounded-4.text-decoration-none.hover-zoom.bg-white(href="/dashboard/collections")
          .card-body.p-4.text-center
            .d-inline-flex.align-items-center.justify-content-center.bg-primary-subtle.text-primary.rounded-circle.mb-3(style="width: 64px; height: 64px;")
              i.fa-solid.fa-bookmark.fs-3
            h4.fw-bold.text-dark Colecciones
            p.text-secondary.mb-0 Organiza tus fotos favoritas en diferentes álbumes.
            
      .col-md-4
        a.card.h-100.border-0.shadow-sm.rounded-4.text-decoration-none.hover-zoom.bg-white(href="/dashboard/following")
          .card-body.p-4.text-center
            .d-inline-flex.align-items-center.justify-content-center.bg-primary-subtle.text-primary.rounded-circle.mb-3(style="width: 64px; height: 64px;")
              i.fa-solid.fa-users.fs-3
            h4.fw-bold.text-dark Seguidos
            p.text-secondary.mb-0 Mira la actividad y las fotos de las personas que sigues.