extends ../layouts/main.pug
include ../mixin/feedbackModal.pug

block metadata 
  script(src="/js/homeIndex.js" type="module" defer)

block content
  if expiredSession
    +successConfirmation(
      "Sesion Expirada",
      `${expiredSession}`,
      "Aceptar"
    )

  //- --- Seccion de bienvenida ---
  .container.py-5.text-center.mt-4
    h1.display-4.fw-bold.text-dark Aquí es donde comienza un gran trabajo
    p.lead.text-secondary.mb-0 Increíbles imágenes para descargar y descubrir

  //- --- Muro de bienvenida ---
  .container.pb-5
    h2.fw-bold.text-dark.mb-4 Fotos populares 
    
    if files && files.length > 0
      .grid-container(style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;")
        include ../partials/_card.pug
    else 
      .text-center.py-5
        i.fa-solid.fa-image.text-secondary.mb-3(style="font-size: 3rem;")
        p.text-secondary= error || message || "No hay fotos disponibles en este momento."

    if (!(success && !files))
      .text-center.mt-5
        button.btn.btn-primary.px-5.py-2.rounded-pill.fw-bold.shadow-sm.wall-more-btn(type="button") Cargar Más