extends ../layout.pug

block metadata
  link(rel="stylesheet", href="/css/_cardStyle.css")
  style.
    .search-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }
    .search-header {
      margin-bottom: 2rem;
    }
    .search-filters {
      display: flex;
      gap: 1rem;
      margin-bottom: 2rem;
      background: #f8fafc;
      padding: 1.5rem;
      border-radius: 12px;
      border: 1px solid #e2e8f0;
      flex-wrap: wrap;
    }
    .filter-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      min-width: 200px;
      flex: 1;
    }
    .filter-group label {
      font-weight: 600;
      color: #334155;
    }
    .filter-group select, .filter-group input {
      padding: 0.75rem;
      border-radius: 8px;
      border: 1px solid #cbd5e1;
      font-size: 1rem;
    }
    .btn-search {
      padding: 0.75rem 1.5rem;
      background: #2563eb;
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      align-self: flex-end;
      height: 45px;
    }

block content
  .search-page
    .search-header
      h1 Buscar Fotografías
      if q
        p Resultados para: <strong>"#{q}"</strong>

    form.search-filters(action="/search" method="GET")
      .filter-group
        label(for="q") Término de búsqueda
        input#q(type="text" name="q" value=q placeholder="Título, descripción...")
      
      .filter-group
        label(for="tag") Etiqueta
        select#tag(name="tag")
          option(value="") Todas
          if listTags
            each t in listTags
              option(value=t selected=(tag === t))= t

      .filter-group
        label(for="type") Tipo de archivo
        select#type(name="type")
          option(value="") Todos
          option(value="image" selected=(type === "image")) Imágenes
          option(value="video" selected=(type === "video")) Videos

      button.btn-search(type="submit") Aplicar Filtros

    if files && files.length > 0
      .grid-container(style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;")
        include ../partials/_card.pug
    else
      .empty-state(style="text-align: center; padding: 4rem 0; color: #64748b;")
        i.fa-solid.fa-magnifying-glass(style="font-size: 3rem; margin-bottom: 1rem; color: #cbd5e1;")
        p No se encontraron resultados que coincidan con tu búsqueda.