extends ../layouts/main.pug
include ../mixin/_emptyState.pug

block metadata

block content
  .container.py-5
    .mb-4
      h1.fw-bold.text-dark Buscar Fotografías
      if q
        p.text-secondary Resultados para: #[strong.text-dark "#{q}"]

    form.bg-white.border.border-secondary-subtle.p-4.rounded-4.shadow-sm.mb-5(action="/search" method="GET")
      .row.g-3.align-items-end
        .col-md-4
          label.form-label.fw-medium.text-secondary.small.mb-1(for="q") Término de búsqueda
          input#q.form-control.rounded-3(type="text" name="q" value=q placeholder="Título, descripción...")
        
        .col-md-3
          label.form-label.fw-medium.text-secondary.small.mb-1(for="tag") Etiqueta
          select#tag.form-select.rounded-3(name="tag")
            option(value="") Todas
            if listTags
              each t in listTags
                option(value=t selected=(tag === t))= t

        .col-md-3
          label.form-label.fw-medium.text-secondary.small.mb-1(for="type") Tipo de archivo
          select#type.form-select.rounded-3(name="type")
            option(value="") Todos
            option(value="image" selected=(type === "image")) Imágenes
            option(value="video" selected=(type === "video")) Videos

        .col-md-2
          button.btn.btn-primary.w-100.rounded-3.fw-bold.py-2(type="submit") Aplicar Filtros

    if files && files.length > 0
      .photo-grid
        include ../partials/_card.pug
    else
      +emptyState('magnifying-glass', 'Sin resultados', 'No se encontraron resultados que coincidan con tu búsqueda.')