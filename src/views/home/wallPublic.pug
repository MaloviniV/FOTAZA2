extends ../layout.pug
include ../mixin/feedbackModal.pug

block metadata 
  link(rel="stylesheet", href="/css/wallStyle.css")
  link(rel="stylesheet", href="/css/_cardStyle.css")
  script(src="/js/wallPublicJS.js" type="module" defer)

block content
  if expiredSession
    +successConfirmation(
      "Sesion Expirada",
      `${expiredSession}`,
      "Aceptar"
    )

  //- --- Seccion de bienvenida ---
  section#main-welcome
    h1 Aquí es donde comienza un gran trabajo
    h2 Increíbles imágenes para descargar

  //- --- Muro de bienvenida ---
  section#main-wall
    h2 Fotos populares 
    .grid-container 
      if (files)
        include ../partials/_card.pug
      else 
        p= error||message
    if (!(success && !files))
      button.wall-more-btn(type="button") Cargar Más