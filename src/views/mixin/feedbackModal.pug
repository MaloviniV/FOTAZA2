mixin feedbackModal(type, title, message, primaryBtnText, primaryBtnLink, secondaryBtnText, secondaryBtnLink)
  - const iconClass = type === 'error' ? 'fa-solid fa-circle-xmark text-danger' : (type === 'success' ? 'fa-solid fa-circle-check text-success' : 'fa-solid fa-circle-info text-info')

  .modal.fade#feedbackModal(tabindex="-1", aria-labelledby="feedbackModalLabel", aria-hidden="true")
    .modal-dialog.modal-dialog-centered
      .modal-content.rounded-4.shadow-lg.border-0
        .modal-body.p-4.text-center
          i(class=`${iconClass} mb-3` style="font-size: 3.5rem;")
          h4.modal-title.fw-bold.mb-2#feedbackModalLabel= title
          p.text-secondary.mb-4= message
          .d-flex.justify-content-center.gap-2
            //- BOTON SECUNDARIO
            if secondaryBtnText
              if secondaryBtnLink
                a.btn.btn-lg.btn-light.rounded-pill.px-4(href=secondaryBtnLink)= secondaryBtnText
              else
                button.btn.btn-lg.btn-light.rounded-pill.px-4(type="button" data-bs-dismiss="modal")= secondaryBtnText
            
            //- BOTON PRIMARIO
            if primaryBtnText
              if primaryBtnLink
                a.btn.btn-lg.btn-primary.rounded-pill.px-4(href=primaryBtnLink)= primaryBtnText
              else
                button.btn.btn-lg.btn-primary.rounded-pill.px-4(type="button" data-bs-dismiss="modal")= primaryBtnText

  //- MUESTRA EL MODAL
  script.
    document.addEventListener('DOMContentLoaded', () => {
      const modalEl = document.getElementById('feedbackModal');
      if (modalEl) {
        const feedbackModal = new bootstrap.Modal(modalEl);
        feedbackModal.show();
      }
    });