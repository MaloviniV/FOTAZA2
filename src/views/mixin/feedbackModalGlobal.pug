mixin feedbackModalGlobal(type, title, message, primaryBtnText, primaryBtnLink, secondaryBtnText, secondaryBtnLink)
  .modal.fade#globalFeedbackModal(tabindex="-1", aria-labelledby="globalFeedbackModalLabel", aria-hidden="true")
    .modal-dialog.modal-dialog-centered
      .modal-content.rounded-4.shadow-lg.border-0
        .modal-body.p-4.text-center
          i#globalModalIcon.mb-3(style="font-size: 3.5rem;")
          h4.modal-title.fw-bold.mb-2#globalFeedbackModalLabel
          p.text-secondary.mb-4#globalModalMessage
          .d-flex.justify-content-center.gap-2
            a.btn.btn-lg.btn-light.rounded-pill.px-4.d-none#globalModalSecondaryBtn(href="#")
            a.btn.btn-lg.btn-primary.rounded-pill.px-4.d-none#globalModalPrimaryBtn(href="#")

  script.
    if (typeof window.showGlobalModal === "undefined") {
      let globalModalInstance = null;
      document.addEventListener('DOMContentLoaded', () => {
        const modalEl = document.getElementById('globalFeedbackModal');
        if (modalEl) {
          globalModalInstance = new bootstrap.Modal(modalEl); //le dice a bootstrap que es un modal
        }
      });

      window.showGlobalModal = function(type, title, message, primaryBtnText, primaryBtnLink, secondaryBtnText, secondaryBtnLink) {
        if (!globalModalInstance) return;

        const iconEl = document.getElementById('globalModalIcon');
        const titleEl = document.getElementById('globalFeedbackModalLabel');
        const messageEl = document.getElementById('globalModalMessage');
        const primaryBtn = document.getElementById('globalModalPrimaryBtn');
        const secondaryBtn = document.getElementById('globalModalSecondaryBtn');

        // ICONO, TITULO, MENSAJE
        iconEl.className = `fa-solid fa-circle-${type === 'error' ? 'xmark text-danger' : (type === 'success' ? 'check text-success' : 'info text-info')} mb-3`;
        titleEl.textContent = title;
        messageEl.textContent = message;

        // BOTON PRIMARIO
        if (primaryBtnText) {
          primaryBtn.textContent = primaryBtnText;
          primaryBtn.classList.remove('d-none');
          if (!primaryBtnLink) {
            primaryBtn.setAttribute('data-bs-dismiss', 'modal');
            primaryBtn.onclick = null;
          } else {
            primaryBtn.onclick = (e) => {
              e.preventDefault();
              if (typeof primaryBtnLink === 'function') {
                primaryBtnLink();
              } else {
                window.location.href = primaryBtnLink;
              }
              globalModalInstance.hide();
            };
            primaryBtn.removeAttribute('data-bs-dismiss');
          }
        } else {
          primaryBtn.classList.add('d-none');
          primaryBtn.onclick = null;
        }

        // BOTON SECUNDARIO
        if (secondaryBtnText) {
          secondaryBtn.textContent = secondaryBtnText;
          secondaryBtn.classList.remove('d-none');
          if (!secondaryBtnLink) {
            secondaryBtn.setAttribute('data-bs-dismiss', 'modal');
            secondaryBtn.onclick = null;
          } else {
            secondaryBtn.onclick = (e) => {
              e.preventDefault();
              if (typeof secondaryBtnLink === 'function') {
                secondaryBtnLink();
              } else {
                window.location.href = secondaryBtnLink;
              }
              globalModalInstance.hide();
            };
            secondaryBtn.removeAttribute('data-bs-dismiss');
          }
        } else {
          secondaryBtn.classList.add('d-none');
          secondaryBtn.onclick = null;
        }

        globalModalInstance.show();
      };
    }