mixin successConfirmation(message, title, primaryBtn, primaryUrl, secondaryBtn)
  .confirmation-modal
    .confirmation-content
      .success-icon ✔️
      h3= title || "¡Operación Exitosa!"
      p= message || "La acción se ha realizado correctamente."
      
      .confirmation-actions
        a.submit_post_btn.success-btn(href=(primaryUrl || "/dashboard"))= primaryBtn || "Volver al Inicio"
        if secondaryBtn
          button.submit_post_btn.cancel-btn(type="button" onclick="this.closest('.confirmation-modal').style.display='none'")= secondaryBtn

  style.
    .confirmation-modal {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0, 0, 0, 0.6);
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 1000;
    }
    .confirmation-content {
      background: #ffffff;
      padding: 2.5rem;
      border-radius: 12px;
      text-align: center;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
      max-width: 450px;
      width: 90%;
    }
    .success-icon {
      font-size: 3.5rem;
      margin-bottom: 1rem;
    }
    .confirmation-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin-top: 1.5rem;
    }
    .success-btn {
      text-decoration: none;
      display: inline-block;
    }
    .cancel-btn {
      background-color: #edf2f7;
      color: #4a5568;
    }