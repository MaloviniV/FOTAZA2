extends ../layouts/main.pug

block metadata
  script(src="/js/profileJS.js" type="module" defer)

block content
  .container.py-5
    //- --- CABECERA DEL USUARIO ---
    - const user = visitedUser
    include ../partials/_userHeader.pug

    //- --- GALERIA DE FOTOS ---
    .mb-4
      h3.fw-bold.text-dark Publicaciones de #{visitedUser.nickname}
      
      if files && files.length > 0
        .grid-container(style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;")
          include ../partials/_card.pug
      else
        .text-center.py-5.bg-white.rounded-4.border.border-secondary-subtle.shadow-sm
          i.fa-solid.fa-camera.text-secondary.mb-3(style="font-size: 3rem; opacity: 0.5;")
          h5.text-dark.fw-medium Este usuario aún no ha subido fotografías
          p.text-secondary Vuelve más tarde para ver sus nuevas publicaciones.
